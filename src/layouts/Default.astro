---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import PageNav from '../components/layout/PageNav.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title}>
  <Header />
  <div class="page-wrapper">
    <PageNav>
      <slot name="sidebar" />
    </PageNav>
    <main class="page-content">
      <slot />
    </main>
  </div>
</BaseLayout>

<style>
  .page-wrapper {
    display: flex;
    min-height: calc(100vh - 56px);
  }

  .page-content {
    flex: 1;
    padding: 32px 40px;
    max-width: 1000px;
    overflow-y: auto;
  }
</style>
