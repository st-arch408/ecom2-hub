---
interface Props {
  label: string;
  id?: string;
  active?: boolean;
  variant?: 'default' | 'srs';
}

const { label, id, active = false, variant = 'default' } = Astro.props;
---

<button
  class:list={['toggle-btn', { active }, variant === 'srs' ? 'srs-variant' : '']}
  id={id}
  data-variant={variant}
  data-active={active ? 'true' : 'false'}
>
  {label}
</button>

<style>
  .toggle-btn {
    font-family: var(--font);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 8px 16px;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text-dim);
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .toggle-btn:hover {
    border-color: var(--accent);
    color: var(--text);
  }

  .toggle-btn.active {
    background: var(--accent);
    color: #000;
    border-color: var(--accent);
    font-weight: 600;
  }

  .toggle-btn.srs-variant.active {
    background: var(--red);
    color: var(--text-bright);
    border-color: var(--red);
  }
</style>

<script>
  document.querySelectorAll('.toggle-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const isActive = btn.getAttribute('data-active') === 'true';
      btn.setAttribute('data-active', isActive ? 'false' : 'true');
      btn.classList.toggle('active');
      btn.dispatchEvent(new CustomEvent('toggle', { bubbles: true, detail: { active: !isActive } }));
    });
  });
</script>
