---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<span class="metric-badge">{text}</span>

<style>
  .metric-badge {
    display: inline-block;
    font-size: 0.65rem;
    padding: 2px 8px;
    border-radius: 20px;
    background: rgba(6, 182, 212, 0.1);
    color: var(--accent);
    white-space: nowrap;
  }
</style>
