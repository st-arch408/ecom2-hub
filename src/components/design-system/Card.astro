---
import MetricBadge from './MetricBadge.astro';
import StatusDot from './StatusDot.astro';

interface Props {
  name: string;
  role: string;
  metric?: string;
  category: 'core' | 'foundation' | 'adjacent' | 'external';
  status: 'active' | 'planned' | 'dependency';
  srsAdvantage?: 'qxo-leads' | 'parity' | 'srs-leads';
  isCenter?: boolean;
  nodeId?: string;
}

const { name, role, metric, category, status, srsAdvantage, isCenter = false, nodeId } = Astro.props;

const categoryColors: Record<string, { bright: string; dim: string }> = {
  core: { bright: 'var(--blue)', dim: 'var(--blue-dim)' },
  foundation: { bright: 'var(--green)', dim: 'var(--green-dim)' },
  adjacent: { bright: 'var(--purple)', dim: 'var(--purple-dim)' },
  external: { bright: 'var(--orange)', dim: 'var(--orange-dim)' },
};

const colors = categoryColors[category];

const srsLabels: Record<string, { label: string; color: string }> = {
  'qxo-leads': { label: 'QXO Leads', color: 'var(--green)' },
  parity: { label: 'Parity', color: 'var(--yellow)' },
  'srs-leads': { label: 'SRS Leads', color: 'var(--red)' },
};
---

<div
  class:list={['card', { 'card-center': isCenter }]}
  data-category={category}
  data-node-id={nodeId}
>
  <div class="card-header">
    <div class="card-icon" style={`background: ${colors.dim}; color: ${colors.bright}`}>
      <span class="icon-dot" style={`background: ${colors.bright}`}></span>
    </div>
    <StatusDot status={status} />
  </div>

  <h3 class="card-name">{name}</h3>
  <p class="card-role">{role}</p>

  {metric && (
    <div class="card-metric">
      <MetricBadge text={metric} />
    </div>
  )}

  {srsAdvantage && (
    <div class="srs-badge" data-srs-badge style={`display: none`}>
      <span class="srs-dot" style={`background: ${srsLabels[srsAdvantage].color}`}></span>
      <span class="srs-label">{srsLabels[srsAdvantage].label}</span>
    </div>
  )}
</div>

<style>
  .card {
    background: var(--bg-card);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 16px;
    min-width: 160px;
    max-width: 200px;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
  }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.4);
    border-color: var(--accent);
  }

  .card.selected {
    border-color: var(--accent);
    box-shadow: 0 0 20px rgba(6, 182, 212, 0.2);
  }

  .card-center {
    background: linear-gradient(135deg, #1a2744, #0f1d33);
    border: 2px solid var(--accent);
    text-align: center;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 8px;
  }

  .card-icon {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .card-name {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-bright);
    margin-bottom: 4px;
  }

  .card-role {
    font-size: 0.7rem;
    color: var(--text-dim);
    line-height: 1.35;
    margin-bottom: 8px;
  }

  .card-metric {
    margin-top: 4px;
  }

  .srs-badge {
    margin-top: 8px;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 8px;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 6px;
  }

  .srs-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .srs-label {
    font-size: 0.6rem;
    color: var(--text-dim);
    font-weight: 500;
  }
</style>
