---
interface Props {
  title: string;
  id?: string;
}

const { title, id = 'slideout-panel' } = Astro.props;
---

<div class="slideout-panel" id={id} data-open="false">
  <div class="slideout-header">
    <h3 class="slideout-title">{title}</h3>
    <button class="slideout-close" aria-label="Close">&times;</button>
  </div>
  <div class="slideout-body" id={`${id}-body`}>
    <slot />
  </div>
</div>

<style>
  .slideout-panel {
    position: fixed;
    right: 0;
    top: 0;
    bottom: 0;
    width: 380px;
    background: var(--bg-panel);
    border-left: 1px solid var(--border);
    z-index: 90;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
    box-shadow: -5px 0 30px rgba(0, 0, 0, 0.3);
  }

  .slideout-panel[data-open='true'] {
    transform: translateX(0);
  }

  .slideout-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }

  .slideout-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-bright);
  }

  .slideout-close {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text-dim);
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }

  .slideout-close:hover {
    background: var(--red);
    border-color: var(--red);
    color: var(--text-bright);
  }

  .slideout-body {
    padding: 16px 20px;
    overflow-y: auto;
    flex: 1;
  }
</style>

<script>
  function setupSlideOutPanels() {
    document.querySelectorAll('.slideout-panel').forEach((panel) => {
      const closeBtn = panel.querySelector('.slideout-close');
      closeBtn?.addEventListener('click', () => {
        panel.setAttribute('data-open', 'false');
        panel.dispatchEvent(new CustomEvent('panel-close', { bubbles: true }));
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.querySelectorAll('.slideout-panel[data-open="true"]').forEach((panel) => {
          panel.setAttribute('data-open', 'false');
          panel.dispatchEvent(new CustomEvent('panel-close', { bubbles: true }));
        });
      }
    });
  }

  setupSlideOutPanels();
  document.addEventListener('astro:after-swap', setupSlideOutPanels);
</script>
