---
interface Props {
  showNav?: boolean;
}

const { showNav = true } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<header class="site-header">
  <div class="header-inner">
    <a href={`${base}`} class="header-logo">
      <span class="logo-text"><span class="brand">QXO</span> Ecom 2.0</span>
    </a>

    {showNav && (
      <nav class="header-nav">
        <a href={`${base}`} class="nav-link">Hub</a>
        <a href={`${base}ecosystem-map`} class="nav-link">Ecosystem Map</a>
        <a href={`${base}journey-map`} class="nav-link">Journey Map</a>
        <a href={`${base}docs`} class="nav-link">Docs</a>
      </nav>
    )}

    <div class="header-toggles">
      <slot />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: linear-gradient(135deg, var(--header-gradient-start), var(--header-gradient-end));
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .header-logo {
    text-decoration: none;
  }

  .logo-text {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.5px;
    color: var(--text-bright);
  }

  .brand {
    color: var(--accent);
    font-weight: 800;
  }

  .header-nav {
    display: flex;
    gap: 4px;
  }

  .nav-link {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-dim);
    text-decoration: none;
    padding: 6px 14px;
    border-radius: 20px;
    transition: all 0.2s ease;
  }

  .nav-link:hover {
    color: var(--text);
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-link.active {
    color: var(--accent);
    background: rgba(6, 182, 212, 0.08);
  }

  .header-toggles {
    display: flex;
    gap: 8px;
    align-items: center;
  }
</style>
